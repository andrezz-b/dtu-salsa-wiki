---
import { extractVideoData } from "@/lib/utils/video";
import { YouTube } from "@astro-community/astro-embed-youtube";
import { FaStar } from "react-icons/fa";

interface Props {
  videoUrls?: string[];
}

const { videoUrls = [] } = Astro.props;

// Process all video URLs
const videos = videoUrls
  .map((url) => extractVideoData(url))
  .filter((video) => video !== null);
---

{
  videos.length > 0 && (
    <div class="mb-10">
      {/* Video Display Area */}
      <div class="rounded-lg ">
        {videos.map((video, index) => (
          <div
            data-video-index={index}
            class={`video-slide ${index === 0 ? "" : "hidden"}`}
          >
            {video.isShort ? (
              <div
                class="max-w-md w-full yt-short-wrapper"
                id={`video-container-${index}`}
              >
                <YouTube id={video.id} params="rel=0&enablejsapi=1" />
              </div>
            ) : (
              <div id={`video-container-${index}`}>
                <YouTube id={video.id} params="rel=0&enablejsapi=1" />
              </div>
            )}
          </div>
        ))}
      </div>

      {/* Tabs - Only show if multiple videos */}
      {videos.length > 1 && (
        <div class="flex items-center gap-2 mt-4 overflow-x-auto pb-2">
          {videos.map((video, index) => (
            <button
              data-tab-index={index}
              class={`video-tab ${index === 0 ? "video-tab-active" : "video-tab-inactive"}`}
            >
              {index === 0 && <FaStar />}
              Video {index + 1}
            </button>
          ))}
        </div>
      )}
    </div>
  )
}

<script>
  // Tab functionality
  const tabs = document.querySelectorAll(".video-tab");
  const slides = document.querySelectorAll(".video-slide");

  // Function to pause any playing YouTube video
  function pauseCurrentVideo() {
    slides.forEach((slide) => {
      const iframe = slide.querySelector("iframe");
      if (iframe && iframe.contentWindow) {
        // Send pause command to YouTube iframe
        iframe.contentWindow.postMessage(
          '{"event":"command","func":"pauseVideo","args":""}',
          "*",
        );
      }
    });
  }

  tabs.forEach((tab) => {
    tab.addEventListener("click", () => {
      const index = parseInt(tab.getAttribute("data-tab-index") || "0");

      // Pause currently playing video before switching
      pauseCurrentVideo();

      // Update tabs
      tabs.forEach((t, i) => {
        if (i === index) {
          t.classList.remove("video-tab-inactive");
          t.classList.add("video-tab-active");
        } else {
          t.classList.remove("video-tab-active");
          t.classList.add("video-tab-inactive");
        }
      });

      // Update slides
      slides.forEach((slide, i) => {
        slide.classList.toggle("hidden", i !== index);
      });
    });
  });
</script>

<style is:global>
  /* Override aspect ratio for YouTube Shorts */
  .yt-short-wrapper lite-youtube {
    aspect-ratio: 9 / 16 !important;
    padding-bottom: 0 !important;
  }

  .yt-short-wrapper lite-youtube::before {
    padding-bottom: 0 !important;
  }
</style>
