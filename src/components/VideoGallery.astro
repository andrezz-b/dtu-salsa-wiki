---
import { YouTube } from "@astro-community/astro-embed-youtube";

interface Props {
  videoUrls?: string[];
}

const { videoUrls = [] } = Astro.props;

interface VideoData {
  id: string;
  isShort: boolean;
}

// Extract YouTube ID and determine if it's a short
const extractVideoData = (url: string): VideoData | null => {
  if (!url) return null;

  // Check if it's a YouTube Short
  const shortsMatch = url.match(/youtube\.com\/shorts\/([^?&#]+)/);
  if (shortsMatch && shortsMatch[1].length === 11) {
    return {
      id: shortsMatch[1],
      isShort: true,
    };
  }

  // Check for regular YouTube video formats
  const regExp = /^.*(youtu.be\/|v\/|u\/\w\/|embed\/|watch\?v=|&v=)([^#&?]*).*/;
  const match = url.match(regExp);
  if (match && match[2].length === 11) {
    return {
      id: match[2],
      isShort: false,
    };
  }

  return null;
};

// Process all video URLs
const videos = videoUrls
  .map((url) => extractVideoData(url))
  .filter((video): video is VideoData => video !== null);
---

{
  videos.length > 0 && (
    <div class="grid grid-cols-1 gap-6 mb-10">
      {videos.map((video) =>
        video.isShort ? (
          // YouTube Short - 9:16 aspect ratio (portrait)
          <div class="yt-short-wrapper rounded-lg overflow-hidden shadow-lg max-w-md w-full">
            <YouTube id={video.id} params="rel=0" />
          </div>
        ) : (
          // Regular YouTube video - default 16:9 aspect ratio
          <div class="rounded-lg overflow-hidden shadow-lg">
            <YouTube id={video.id} params="rel=0" />
          </div>
        ),
      )}
    </div>
  )
}

<style is:global>
  /* Override aspect ratio for YouTube Shorts */
  .yt-short-wrapper lite-youtube {
    aspect-ratio: 9 / 16 !important;
    padding-bottom: 0 !important;
  }

  .yt-short-wrapper lite-youtube::before {
    padding-bottom: 0 !important;
  }
</style>
