---
import Base from "@/layouts/Base.astro";
import ExplorerSidebar from "@/layouts/helpers/ExplorerSidebar.astro";
import Breadcrumbs from "@/components/ui/Breadcrumbs";
import LevelBadge from "@/components/ui/LevelBadge";
import { YouTube } from "@astro-community/astro-embed-youtube";
import { FaLink } from "react-icons/fa";
import type { ComponentProps } from "astro/types";
import type { BreadcrumbPart } from "@/components/ui/Breadcrumbs";
import type { CollectionEntry } from "astro:content";

interface Props {
  title: string;
  type: string;
  level?: string;
  videoIds?: string[];
  breadcrumbs: BreadcrumbPart[];
  sidebarProps: ComponentProps<typeof ExplorerSidebar>;
  variations?: CollectionEntry<"moves">[] | CollectionEntry<"concepts">[];
  variationsBasePath?: string;
}

const {
  title,
  type,
  level,
  videoIds = [],
  breadcrumbs,
  sidebarProps,
  variations = [],
  variationsBasePath = "/moves",
} = Astro.props;
const pageUrl = Astro.url.href;

// Smart limit based on estimated space usage (characters)
// Assume ~50-60 characters worth of content fits comfortably before needing "more"
const estimateVariationWidth = (variation: any) => {
  const titleLength = variation.data.title.length;
  const levelBadgeWidth = variation.data.level ? 10 : 0; // Estimate for level dot + spacing
  const paddingAndSpacing = 8; // px-3, gap-2, etc.
  return titleLength + levelBadgeWidth + paddingAndSpacing;
};

let totalWidth = 0;
let visibleCount = 0;
const MAX_WIDTH = 70; // Characters worth of content

for (const variation of variations) {
  const width = estimateVariationWidth(variation);
  if (totalWidth + width <= MAX_WIDTH || visibleCount === 0) {
    totalWidth += width;
    visibleCount++;
  } else {
    break;
  }
}

const visibleVariations = variations.slice(0, visibleCount);
const hiddenVariations = variations.slice(visibleCount);
const hasHiddenVariations = hiddenVariations.length > 0;
---

<Base title={title}>
  <section class="section pt-6">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
        {/* Sidebar (Left on Desktop, Bottom on Mobile) */}
        <div class="lg:col-span-3 order-2 lg:order-1">
          <div class="h-auto">
            <ExplorerSidebar {...sidebarProps} />
          </div>
        </div>

        {/* Main Content (Right on Desktop, Top on Mobile) */}
        <article class="lg:col-span-9 order-1 lg:order-2">
          {/* Header */}
          <div class="mb-6">
            <Breadcrumbs className="mb-4" parts={breadcrumbs} />
            <div class="flex items-center gap-3 mb-3">
              {level && <LevelBadge level={level} size="md" />}
              <span
                class="px-3 py-1 rounded-full bg-gray-100 text-gray-800 text-sm font-bold uppercase tracking-wider dark:bg-gray-700 dark:text-gray-200"
              >
                {type}
              </span>
            </div>
            <div class="block">
              <h1 class="h1">
                {title}
                <button
                  id="copy-link-btn"
                  class="inline-flex items-center justify-center p-2 rounded-lg bg-gray-100 hover:bg-gray-200 dark:bg-gray-700 dark:hover:bg-gray-600 transition-colors ml-2 align-middle"
                  title="Copy link to clipboard"
                  data-url={pageUrl}
                >
                  <FaLink
                    className="w-4 h-4 text-gray-600 dark:text-gray-300"
                  />
                </button>
              </h1>

              {/* Variations Section */}
              {
                variations.length > 0 && (
                  <div class="mt-4">
                    <div class="flex flex-col gap-2">
                      <span class="text-gray-500 dark:text-gray-400 text-xs uppercase tracking-wider font-medium">
                        Variations
                      </span>
                      <div class="flex flex-wrap gap-2">
                        {visibleVariations.map((variation) => (
                          <a
                            href={`${variationsBasePath}/${variation.id}`}
                            class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-300 text-sm font-medium hover:bg-blue-200 dark:hover:bg-blue-900/50 transition-colors"
                          >
                            {variation.data.level && (
                              <LevelBadge
                                level={variation.data.level}
                                variant="dot"
                                size="sm"
                                client:load
                              />
                            )}
                            <span>{variation.data.title}</span>
                          </a>
                        ))}
                        {hasHiddenVariations && (
                          <>
                            <div
                              class="variations-hidden hidden flex-wrap gap-2"
                              style="display: none;"
                            >
                              {hiddenVariations.map((variation) => (
                                <a
                                  href={`${variationsBasePath}/${variation.id}`}
                                  class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-300 text-sm font-medium hover:bg-blue-200 dark:hover:bg-blue-900/50 transition-colors"
                                >
                                  {variation.data.level && (
                                    <LevelBadge
                                      level={variation.data.level}
                                      variant="dot"
                                      size="sm"
                                      client:load
                                    />
                                  )}
                                  <span>{variation.data.title}</span>
                                </a>
                              ))}
                            </div>
                            <button class="show-more-btn inline-flex items-center gap-1 px-3 py-1.5 rounded-full bg-gray-100 text-gray-700 dark:bg-gray-700 dark:text-gray-300 text-sm font-medium hover:bg-gray-200 dark:hover:bg-gray-600 transition-colors">
                              <span>Show {hiddenVariations.length} more</span>
                              <svg
                                class="w-4 h-4 transition-transform"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                              >
                                <path
                                  stroke-linecap="round"
                                  stroke-linejoin="round"
                                  stroke-width="2"
                                  d="M19 9l-7 7-7-7"
                                />
                              </svg>
                            </button>
                          </>
                        )}
                      </div>
                    </div>
                  </div>
                )
              }

              {/* Optional Header Content (e.g. Difficulty, Aliases) */}
              <slot name="header-bottom" />
            </div>
          </div>

          {/* Videos */}
          {
            videoIds.length > 0 && (
              <div class="grid grid-cols-1 gap-6 mb-10">
                {videoIds.map((id) => (
                  <div class="rounded-lg overflow-hidden shadow-lg">
                    <YouTube id={id} params="rel=0" />
                  </div>
                ))}
              </div>
            )
          }

          {/* Content */}
          <div
            class="content mb-10 prose-a:text-accent prose-a:no-underline prose-a:hover:underline"
          >
            <slot />
          </div>
        </article>
      </div>
    </div>
  </section>
</Base>

<script>
  // Handle view transitions
  document.addEventListener("astro:page-load", () => {
    const copyBtn = document.getElementById("copy-link-btn");
    if (copyBtn) {
      copyBtn.addEventListener("click", async () => {
        const url = copyBtn.getAttribute("data-url") || window.location.href;
        try {
          await navigator.clipboard.writeText(url);

          // Visual feedback
          copyBtn.classList.add(
            "!bg-green-100",
            "dark:!bg-green-700",
            "text-green-600",
            "dark:text-green-200",
          );

          setTimeout(() => {
            copyBtn.classList.remove(
              "!bg-green-100",
              "dark:!bg-green-700",
              "text-green-600",
              "dark:text-green-200",
            );
          }, 1000);
        } catch (err) {
          console.error("Failed to copy link:", err);
        }
      });
    }

    // Variations: Inline Expand Button
    const showMoreBtn = document.querySelector(".show-more-btn");
    const hiddenVariations =
      document.querySelector<HTMLElement>(".variations-hidden");
    if (showMoreBtn && hiddenVariations) {
      showMoreBtn.addEventListener("click", () => {
        const isHidden = hiddenVariations.style.display === "none";
        if (isHidden) {
          hiddenVariations.style.display = "flex";
          showMoreBtn.querySelector("span")!.textContent = "Show less";
          showMoreBtn.querySelector("svg")?.classList.add("rotate-180");
        } else {
          hiddenVariations.style.display = "none";
          const count = hiddenVariations.children.length;
          showMoreBtn.querySelector("span")!.textContent = `Show ${count} more`;
          showMoreBtn.querySelector("svg")?.classList.remove("rotate-180");
        }
      });
    }
  });
</script>
